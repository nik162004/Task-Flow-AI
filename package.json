{
  "name": "taskflow-ai",
  "version": "1.0.0",
  "private": true,
  "description": "TaskFlow AI multi-tenant SaaS project management platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @taskflow/api & npm run dev --workspace @taskflow/web",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace @taskflow/api",
    "db:migrate": "npm run db:migrate --workspace @taskflow/api",
    "db:seed": "npm run db:seed --workspace @taskflow/api",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "typescript": "^5.5.3"
  }
}
